# ───────────────────────────────────────────────────────────
# scraper — 환경 변수 예시 (실제 값은 Railway Variables 에 설정)
# 루트 .env.example 의 스크래퍼 항목과 동일 키. 로컬 단독 실행 시 이 파일을
# .env 로 복사해 채운다(.env 는 커밋 금지).
# ───────────────────────────────────────────────────────────

# ── Supabase 적재 (service_role: RLS 우회, 절대 클라이언트 노출 금지) ──
# SUPABASE_URL 미설정 시 NEXT_PUBLIC_SUPABASE_URL 을 폴백으로 사용.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── grider 관리자 포털 (PHP 서버렌더, 세션쿠키 기반) ──────────
# 셋 다 채워져야 실제 수집 시도. 하나라도 비면 골격 모드(수집 스킵).
# 자격증명은 Railway Variables 주입(하드코딩 금지).
ADMIN_PORTAL_URL=https://jangboo.grider.ai/dashboard
ADMIN_PORTAL_ID=
ADMIN_PORTAL_PASSWORD=

# ── 스케줄/동작 튜닝 ─────────────────────────────────────────
SCRAPE_INTERVAL_SECONDS=60      # 수집 주기(초) — 한 틱 시간 예산이기도 함(초과 시 다음 틱 스킵)
SCRAPE_TIMEZONE=Asia/Seoul      # 영업일(snapshot_date) 판정 기준 TZ
SCRAPE_MAX_RETRIES=3            # 사이클 실패 시 재시도 횟수(지수 백오프)
SCRAPE_NAV_TIMEOUT_MS=30000     # Playwright 내비게이션/대기 타임아웃(ms)
HEADLESS=true                   # 헤드리스 크롬 (디버깅 시 false)
STORAGE_STATE_PATH=./.session/storage-state.json  # 로그인 세션(쿠키) 영속 경로
LOG_LEVEL=info                  # debug | info | warn | error

# 운영 금지. true 면 grider 미접속·mock 데이터로 적재 파이프라인만 검증.
SCRAPE_MOCK=
