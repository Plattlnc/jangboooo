# ───────────────────────────────────────────────────────────
# scraper — 환경 변수 예시 (실제 값은 Railway Variables 에 설정)
# 루트 .env.example / docs/env-setup.md 의 스크래퍼 항목과 동일 키.
# 로컬 단독 실행 시 이 파일을 .env 로 복사해 채운다(.env 는 커밋 금지).
# 키/기본값은 src/config.ts(EnvSchema) 가 단일 진실원천(SoT).
# ───────────────────────────────────────────────────────────

# ── Supabase 적재 (service_role: RLS 우회, 절대 클라이언트 노출 금지) ──
# SUPABASE_URL 미설정 시 NEXT_PUBLIC_SUPABASE_URL 을 폴백으로 사용.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # 필수. 미설정 시 부팅 차단(exit 1)

# ── 배민 deliverycenter 소스 (React SPA, 로그인 세션=storageState 기반) ──
# 소스는 SMS 2FA 때문에 무인 ID/PW 로그인 불가 → 1회 캡처한 로그인 세션을 주입한다.
# (grider ID/PW 방식은 폐기됨. ADMIN_PORTAL_ID/PASSWORD 같은 키는 더 이상 사용 안 함.)
# ADMIN_PORTAL_URL 미설정 → 골격 모드(상주만, 수집 스킵).
ADMIN_PORTAL_URL=https://deliverycenter.baemin.com

# 로컬 `npm run capture`(headed 로그인 + SMS 2FA + 자동로그인)로 생성된
# storageState JSON 의 base64 한 줄. Railway 등 영속 FS 없는 환경에서 부팅 시 파일로 복원.
# 시크릿 — Railway Variables 에 주입. 세션 만료 시 capture 재실행해 갱신.
STORAGE_STATE_B64=
# 로그인 세션(쿠키) 영속 경로. 로컬 캡처/복원 대상 파일.
STORAGE_STATE_PATH=./.session/storage-state.json

# ── 스케줄/동작 튜닝 (괄호 = config.ts 기본값) ───────────────
SCRAPE_INTERVAL_SECONDS=60       # 수집 주기(초) = 한 틱 시간 예산(초과 시 다음 틱 스킵)
SCRAPE_PAGE_SIZE=200             # delivery-status 1콜 행 수(서버 상한 시 페이지 루프 폴백)
SCRAPE_TIMEZONE=Asia/Seoul       # 영업일(snapshot_date) 판정 기준 TZ
SCRAPE_MAX_RETRIES=3             # 사이클 실패 시 재시도 횟수(지수 백오프)
SCRAPE_NAV_TIMEOUT_MS=30000      # Playwright 내비게이션/대기 타임아웃(ms)
HEADLESS=true                    # 헤드리스 크롬 (디버깅 시 false)
LOG_LEVEL=info                   # debug | info | warn | error

# 운영 금지. true 면 배민 미접속·mock 데이터로 적재 파이프라인만 검증.
SCRAPE_MOCK=

# ── 공동목표(달성현황 beta) = 구글 Looker Studio 임베드 (best-effort) ──
# 배민 세션과 별개의 "구글 로그인 세션"이 필요. 미설정 시 공동목표 수집만 스킵(배달현황 영향 없음).
# 로컬 `npm run capture:google`(headed 구글 로그인)로 생성한 구글 storageState JSON 의 base64 한 줄.
GOOGLE_STORAGE_STATE_B64=
GOOGLE_STORAGE_STATE_PATH=./.session/google-state.json
# Looker 임베드 리포트 URL(미설정 시 config.ts DEFAULT_GOAL_REPORT_URL 사용 — 공개 임베드 ID, 시크릿 아님).
GOAL_REPORT_URL=
