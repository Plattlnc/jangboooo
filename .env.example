# ───────────────────────────────────────────────────────────
# jangboooo — 환경 변수 예시 (실제 값은 .env.local / Railway secrets)
# ───────────────────────────────────────────────────────────

# Supabase (대시보드 웹 + 스크래퍼 공용)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # 서버/스크래퍼 전용, 절대 클라이언트 노출 금지

# 라이더 로그인 세션 서명 (HMAC) — 서버 전용. 아무 긴 랜덤 문자열(≥16자) 권장.
# 라이더 인증 = rider_id(admin_rider_id) + 휴대폰 뒤 4자리. 카카오/본인인증 폐기.
SESSION_SECRET=YOUR_LONG_RANDOM_SECRET

# 데모 모드 — true 면 로그인 우회 + 목 데이터(운영 금지). 실데이터 운영 시 false/미설정.
NEXT_PUBLIC_DEMO_MODE=

# ROADING 사고접수 임베드 iframe origin. 미설정 시 프로덕션 기본값 사용.
# 로컬/스테이징 ROADING 테스트 시 해당 URL로 오버라이드 (예: http://localhost:8081).
NEXT_PUBLIC_ROADING_ORIGIN=https://loading-app-two.vercel.app

# ── 스크래퍼 (Railway 전용) ───────────────────────────────
# 소스: 배민커넥트비즈(deliverycenter) — React SPA. 세션(storageState) 기반.
# ID/PW 대신 1회 캡처한 로그인 세션을 주입(SMS 2FA 우회). 비우면 골격 모드(수집 스킵).
ADMIN_PORTAL_URL=https://deliverycenter.baemin.com
SCRAPE_PAGE_SIZE=200
SCRAPE_INTERVAL_SECONDS=60
# 로컬 `npm run capture`(headed 로그인+2FA+자동로그인)로 생성된 storageState 의 base64.
# Railway Variables 에 주입(시크릿). 세션 만료 시 capture 재실행해 갱신.
STORAGE_STATE_B64=
# 운영 금지. true 면 배민 미접속·mock 데이터로 적재 파이프라인만 검증.
SCRAPE_MOCK=
