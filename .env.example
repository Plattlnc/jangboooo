# ───────────────────────────────────────────────────────────
# jangboooo — 환경 변수 예시 (실제 값은 .env.local / Railway secrets)
# ───────────────────────────────────────────────────────────

# Supabase (대시보드 웹 + 스크래퍼 공용)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # 서버/스크래퍼 전용, 절대 클라이언트 노출 금지

# Kakao OAuth (라이더 간편로그인) — Supabase Auth Provider에 등록
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# 본인인증 — 카카오 본인확인 (휴대폰 실명확인)
# 키 비우면 PROVIDER_NOT_CONFIGURED 로 안전차단(카카오 로그인 자체는 동작).
IDENTITY_VERIFY_PROVIDER=kakao
KAKAO_IDENTITY_CLIENT_ID=
KAKAO_IDENTITY_CLIENT_SECRET=
KAKAO_IDENTITY_REDIRECT_URI=
# 개발/테스트 전용 샌드박스 (운영 금지). true 면 'mock:01012345678' 토큰 허용.
IDENTITY_VERIFY_SANDBOX=

# ── 스크래퍼 (Railway 전용) ───────────────────────────────
# 관리자 소스 시스템: grider (PHP 서버렌더, 세션쿠키 기반). URL 확정.
# 자격증명은 Railway Variables 로 주입(하드코딩 금지). 비우면 골격 모드(수집 스킵).
ADMIN_PORTAL_URL=https://jangboo.grider.ai/dashboard
ADMIN_PORTAL_ID=
ADMIN_PORTAL_PASSWORD=
SCRAPE_INTERVAL_SECONDS=60
# 운영 금지. true 면 grider 미접속·mock 데이터로 적재 파이프라인만 검증.
SCRAPE_MOCK=
