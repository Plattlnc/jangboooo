# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...단, 예시 파일은 커밋한다(시크릿 없음, 루트/하위 패키지 모두).
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code agent worktrees / local
.claude/

# CI workflow는 PAT workflow 스코프 발급 후 추가(현재 보류)
.github/

# 시안 원본 번들(22MB, 레퍼런스용) — 커밋 제외
/배달 장부*.html
